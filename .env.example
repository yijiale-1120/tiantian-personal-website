# 数据库（前后端共用，后端 Nest 读取）
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5433/my_personal_website
PORT=3001
DATABASE_SSL=false

# Nest JWT（生产环境务必使用长随机串）
JWT_SECRET=change-me-to-a-long-random-secret

# 首次启动时若不存在该用户则创建（bcrypt 存储）。不设则跳过种子。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 可选：CORS 允许的前端来源，逗号分隔。不设则反射任意来源（开发方便）。
# FRONTEND_ORIGIN=http://localhost:3000

# 前端：生产环境若 API 与站点不同域，填后端根地址，例如 https://api.example.com
# 开发环境下由于不再使用 Vite 代理，通常也需要填写，例如 http://localhost:3000
# 留空则使用相对路径 /api（需同域或网关反代）
# NEXT_PUBLIC_API_BASE_URL=
#
# 若站点部署在子路径下，可显式声明 basePath，需与 next.config.ts 保持一致
# NEXT_PUBLIC_BASE_PATH=/tiantian-personal-website
